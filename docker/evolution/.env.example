# ─────────────────────────────────────────────────────────────
# Evolution API — variáveis do docker-compose
# Copie para .env (cp .env.example .env) e ajuste os valores.
# ─────────────────────────────────────────────────────────────

# Porta exposta no host (acesse o manager em http://localhost:8080/manager)
EVOLUTION_PORT=8080

# URL pública/local pela qual a Evolution se enxerga (usada em links de mídia/QR)
SERVER_URL=http://localhost:8080

# Chave mestra da API. TROQUE por um valor aleatório forte.
# Gere com:  openssl rand -hex 32
AUTHENTICATION_API_KEY=troque-esta-chave-por-uma-aleatoria

# ── Postgres ──
POSTGRES_USER=evolution
POSTGRES_PASSWORD=troque-esta-senha-do-postgres
POSTGRES_DB=evolution

# ── Webhook global (opcional) ──
# Em vez de configurar por instância, você pode mandar TODOS os eventos
# de TODAS as instâncias para uma URL só.
# No WSL/Docker Desktop, para alcançar o Laravel rodando no host use host.docker.internal.
WEBHOOK_GLOBAL_ENABLED=false
WEBHOOK_GLOBAL_URL=http://host.docker.internal:8000/tenant-da-empresa/webhooks/whatsapp
